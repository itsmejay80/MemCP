# MemCP local storage
QDRANT_MODE=local
QDRANT_PATH=~/.memcp/db

# Optional auth (recommended for shared/hosted usage)
MEMCP_AUTH_TOKEN=replace-with-a-strong-token
# MEMCP_REQUIRE_AUTH=true

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ATOMIC_EXTRACT=true
TOP_K=10
MIN_SCORE=0.2
